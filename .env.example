# ============================================================
#  Agente para Iglesias - Configuracion
#  Copia este archivo como ".env" y ajusta los valores.
#  NUNCA pongas claves reales dentro del codigo fuente.
# ============================================================

# ----- Servidor web (interfaz) -----
WEB_PORT=3000

# ----- FreeShow -----
# Activa la API en FreeShow: Settings -> Connections -> API/WebSocket.
FREESHOW_HOST=127.0.0.1
# Puerto REST (por defecto 5506).
FREESHOW_PORT=5506
# Puerto WebSocket / socket.io (por defecto 5505).
FREESHOW_WS_PORT=5505
# Transporte para crear contenido: rest (recomendado) o ws.
# Las lecturas (get_*) usan siempre REST.
FREESHOW_TRANSPORT=rest

# ----- Proveedor de Biblia -----
# local  -> FreeShow (Bibles/*.fsb) -> JSON local -> SQLite local -> API.Bible si hay clave
# apibible -> scripture.api.bible (requiere BIBLE_API_KEY)
# json   -> solo archivos JSON en LOCAL_BIBLE_PATH
# sqlite -> solo base SQLite local
BIBLE_PROVIDER=local

# Clave de API.Bible (https://scripture.api.bible). Solo si usas apibible o como
# respaldo final cuando una version no esta instalada en FreeShow ni en local.
BIBLE_API_KEY=

# Carpeta raiz de datos de FreeShow (contiene Bibles/, Shows/, etc.).
# Vacio = usa el default de FreeShow: ~/Documents/FreeShow (o la carpeta que
# hayas configurado en FreeShow -> Settings -> Data si la cambiaste).
FREESHOW_DATA_PATH=

# Carpeta con biblias en JSON (esquema en docs/) cuando usas json/local.
# Solo se consulta si la version no esta instalada en FreeShow.
LOCAL_BIBLE_PATH=./data/biblias

# Version usada cuando la referencia no indica una (ej. "Juan 3:16" sin version).
DEFAULT_VERSION=RVR1960

# ----- Proveedor de IA (NO requerido por el Modulo 1) -----
# Queda listo para futuros modulos. Opciones: claude | openai | gemini | deepseek | ollama
AI_PROVIDER=claude
AI_API_KEY=

# ----- Plantilla visual activa (archivo en ./plantillas sin .json) -----
TEMPLATE=Escritura

# ----- Base de datos local -----
DB_PATH=./data/app.db

# ----- Actualizaciones automaticas (solo en app instalada) -----
# Canal: stable = releases oficiales | beta = versiones previas de prueba
UPDATE_CHANNEL=stable

# ----- Comportamiento -----
# Que hacer si ya existe un proyecto con el mismo nombre: skip | replace
ON_DUPLICATE=skip
# error | warn | info | debug
LOG_LEVEL=info
# true = no envia nada a FreeShow, solo registra el JSON generado (para pruebas)
DRY_RUN=false
